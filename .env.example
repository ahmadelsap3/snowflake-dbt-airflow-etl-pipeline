# Snowflake Connection Environment Variables
# Copy this file to .env and fill in your actual credentials

SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT_IDENTIFIER     # e.g., xy12345.us-east-1
SNOWFLAKE_USER=YOUR_SNOWFLAKE_USERNAME        # e.g., john.doe@company.com
SNOWFLAKE_PASSWORD=YOUR_SNOWFLAKE_PASSWORD    # Your Snowflake password
SNOWFLAKE_WAREHOUSE=YOUR_WAREHOUSE_NAME       # Your warehouse name
SNOWFLAKE_DATABASE=YOUR_DATABASE_NAME         # Database to use
SNOWFLAKE_ROLE=YOUR_ROLE                      # Your role (e.g., ACCOUNTADMIN)
